{
  "name": "clawgame",
  "private": true,
  "version": "0.1.0",
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel build:shared dev:server dev:web",
    "dev:web": "npm run dev -w @clawgame/web",
    "dev:server": "npm run dev -w @clawgame/server",
    "build": "npm-run-all build:shared build:server:only build:web:only",
    "build:shared": "npm run build -w @clawgame/shared",
    "build:server": "npm-run-all build:shared build:server:only",
    "build:server:only": "npm run build -w @clawgame/server",
    "build:web": "npm-run-all build:shared build:web:only",
    "build:web:only": "npm run build -w @clawgame/web",
    "start": "npm run start -w @clawgame/server",
    "test:unit:server": "npm run test:unit -w @clawgame/server",
    "test:e2e": "npm run test -w @clawgame/e2e",
    "test:e2e:real-agent": "cross-env RUN_REAL_AGENT_PROMPT=1 npm run test -w @clawgame/e2e -- --grep \"real agent\""
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "npm-run-all": "^4.1.5"
  }
}
