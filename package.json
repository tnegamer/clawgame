{
  "name": "clawgame",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:server dev:web",
    "dev:web": "npm run dev -w @clawgame/web",
    "dev:server": "npm run dev -w @clawgame/server",
    "build": "npm-run-all build:shared build:server build:web",
    "build:shared": "npm run build -w @clawgame/shared",
    "build:server": "npm run build -w @clawgame/server",
    "build:web": "npm run build -w @clawgame/web",
    "start": "npm run start -w @clawgame/server",
    "test:e2e": "npm run test -w @clawgame/e2e"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
