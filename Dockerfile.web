FROM node:22-alpine

WORKDIR /app

COPY package*.json ./
COPY packages/web/package*.json packages/web/

RUN npm ci

COPY . .

ARG VITE_SKILL_URL
ENV VITE_SKILL_URL=${VITE_SKILL_URL}

RUN npm run build:web

ENV NODE_ENV=production
ENV PORT=5173

EXPOSE 5173

CMD ["sh", "-lc", "npm run preview -w @clawgame/web -- --host 0.0.0.0 --port ${PORT} --strictPort"]
